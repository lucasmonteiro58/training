rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ajuste as regras conforme seu app (leitura/escrita por usuário autenticado).
    // A Cloud Function usa o Admin SDK e ignora estas regras.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

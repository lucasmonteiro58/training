# Firebase / Google Services (Android)
# Copie para .env e preencha com os valores do seu projeto no Firebase Console.
# Nunca commite o arquivo .env (ele já está no .gitignore).

FIREBASE_PROJECT_NUMBER=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MOBILESDK_APP_ID=
FIREBASE_ANDROID_PACKAGE_NAME=com.trainingapp.training_native
FIREBASE_OAUTH_CLIENT_ID=
FIREBASE_API_KEY=
